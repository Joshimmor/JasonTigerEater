                {
                  "value": "code",
                  "title": "Code"
                },
                {
                  "value": "underline",
                  "title": "Underline"
                },
                {
                  "value": "strike-through",
                  "title": "Strike"
                }
              ]
            },
            "of": [],
            "styles": [
              {
                "value": "normal",
                "title": "Normal"
              },
              {
                "value": "h1",
                "title": "Heading 1"
